{
  "name": "theme-doctor",
  "version": "0.1.0",
  "description": "AI-powered WooCommerce theme QA — crawl, judge, and auto-fix any registered theme set.",
  "keywords": [
    "woocommerce",
    "wordpress",
    "theme",
    "qa",
    "ai",
    "claude",
    "testing"
  ],
  "homepage": "https://github.com/nicholasgasior/theme-doctor",
  "license": "MIT",
  "author": "Theme Doctor Contributors",
  "type": "module",
  "bin": {
    "theme-doctor": "./bin/theme-doctor.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "defaults/"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@axe-core/playwright": "^4.10.1",
    "@wp-playground/cli": "^3.1.20",
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "got": "^14.4.4",
    "ms": "^2.1.3",
    "odiff-bin": "^3.1.2",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "p-limit": "^6.1.0",
    "playwright": "^1.49.1",
    "simple-git": "^3.27.0",
    "table": "^6.9.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/adm-zip": "^0.5.7",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
